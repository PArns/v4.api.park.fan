{
  "name": "park-fan-api",
  "version": "4.10.0",
  "description": "Real-time theme park data aggregation API providing wait times, occupancy insights, and ML-ready analytics",
  "author": "Patrick Arns",
  "private": true,
  "license": "GPL-3.0-only",
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\"",
    "build": "nest build",
    "postbuild": "ts-node -r tsconfig-paths/register scripts/generate-swagger-spec.ts || echo '⚠️  Swagger spec generation skipped (will be generated at runtime)'",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "NODE_NO_WARNINGS=1 nest start",
    "dev": "NODE_NO_WARNINGS=1 nest start --watch",
    "start:debug": "NODE_NO_WARNINGS=1 nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint . --fix",
    "test": "NODE_ENV=test jest --config jest.config.json",
    "test:watch": "NODE_ENV=test jest --watch --config jest.config.json",
    "test:cov": "NODE_ENV=test jest --coverage --config jest.config.json",
    "test:debug": "NODE_ENV=test node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand --config jest.config.json",
    "test:e2e": "NODE_ENV=test jest --config ./test/jest-e2e.json --runInBand",
    "test:e2e:watch": "NODE_ENV=test jest --config ./test/jest-e2e.json --watch --runInBand",
    "test:e2e:cov": "NODE_ENV=test jest --config ./test/jest-e2e.json --coverage --runInBand",
    "test:all": "npm run test && npm run test:e2e",
    "test:all:cov": "npm run test:cov && npm run test:e2e:cov",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:reset": "docker-compose down -v && docker-compose up -d postgres redis",
    "db:test:create": "docker exec -it parkfan_postgres psql -U parkfan -c 'CREATE DATABASE parkfan_test;'",
    "db:test:drop": "docker exec -it parkfan_postgres psql -U parkfan -c 'DROP DATABASE IF EXISTS parkfan_test;'",
    "db:test:reset": "npm run db:test:drop && npm run db:test:create",
    "clear-queues": "ts-node scripts/clear-queues.ts",
    "job:ml-train": "ts-node scripts/trigger-ml-training.ts",
    "job:stats-backfill": "ts-node scripts/trigger-stats-backfill.ts",
    "job:baselines-recalc": "ts-node scripts/trigger-baseline-recalculation.ts",
    "job:clear-calendar-cache": "ts-node scripts/clear-calendar-cache.ts",
    "job:children-sync": "ts-node scripts/trigger-children-sync.ts",
    "job:clear-cache": "ts-node scripts/clear-cache.ts"
  },
  "dependencies": {
    "@elsikora/string-similarity": "^1.0.1",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/swagger": "^11.2.7",
    "@nestjs/typeorm": "^11.0.1",
    "axios": "^1.15.0",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "ioredis": "^5.10.1",
    "luxon": "^3.7.2",
    "marked": "^18.0.0",
    "maxmind": "^5.0.6",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "slugify": "^1.6.9",
    "tar": "^7.5.13",
    "themeparks": "^6.0.1",
    "transliteration": "^2.6.1",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.19",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.18",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "dotenv": "^17.4.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "overrides": {
      "qs": ">=6.14.2",
      "multer": ">=2.1.1",
      "serialize-javascript": ">=7.0.3",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "minimatch@>=10.0.0 <10.2.3": "10.2.3",
      "ajv@<6.14.0": "6.14.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": "8.18.0",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
