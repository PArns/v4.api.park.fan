# Application
NODE_ENV=development
PORT=3000

# Database - PostgreSQL with TimescaleDB
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=parkfan
DB_PASSWORD=parkfan_dev_password
DB_DATABASE=parkfan
DB_SYNCHRONIZE=true
DB_LOGGING=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Bull Queue
BULL_PREFIX=parkfan

# Database connection pool (optional)
# DB_POOL_SIZE=30

# Origin rate limiting (circuit breaker; tunable). Keyed on the real
# client IP (CF-Connecting-IP behind Cloudflare). Set THROTTLE_LIMIT=0
# to disable. Limit is per TTL window (seconds).
# THROTTLE_TTL=60
# THROTTLE_LIMIT=300
# Bypass allow-list: a request whose THROTTLE_BYPASS_HEADER matches one of
# the comma-separated THROTTLE_BYPASS_KEYS skips rate limiting (used by our
# own frontend). Empty keys = no bypass. Keep keys secret; rotate via env.
# THROTTLE_BYPASS_HEADER=x-auth-key
# THROTTLE_BYPASS_KEYS=replace-with-a-long-random-secret

GOOGLE_API_KEY=SOME_GOOGLE_API_KEY

# GeoIP (GeoLite2-City) – optional; used for /discovery/nearby when no lat/lng provided
# Download: https://download.maxmind.com/geoip/databases/GeoLite2-City/download?suffix=tar.gz (Basic Auth)
# GEOIP_MAXMIND_ACCOUNT_ID=
# GEOIP_MAXMIND_LICENSE_KEY=
# GEOIP_DATABASE_PATH=./data/GeoLite2-City.mmdb

# External APIs (to be added in Phase 2)
# THEMEPARKS_API_KEY=
# GEOCODING_API_KEY=
# OPENWEATHER_API_KEY=
