# parkfan backup config — copy to /opt/parkfan/backup.env on dockerhost
# chmod 600 /opt/parkfan/backup.env  (contains secrets!)

# ── Samba NAS ──────────────────────────────────────────────────────────────────
BACKUP_NAS_HOST=192.168.100.100
BACKUP_NAS_SHARE=Backups
BACKUP_NAS_USER=backup-user
BACKUP_NAS_PASSWORD=CHANGEME

# ── PostgreSQL (host-exposed port) ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=parkfan
DB_PASSWORD=CHANGEME
DB_DATABASE=parkfan

# ── Retention ──────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=7
BACKUP_ML_MODELS_KEEP=7

# ── Paths ──────────────────────────────────────────────────────────────────────
ML_MODELS_DIR=/data/parkfan/ml-models
