# Application
NODE_ENV=production
PORT=3000
API_PREFIX=v1

# Database - PostgreSQL with TimescaleDB
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=parkfan
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_DATABASE=parkfan
DB_SYNCHRONIZE=true
DB_LOGGING=false
# Connection pool size (default 30). Raise alongside Postgres max_connections
# if you run multiple API instances.
# DB_POOL_SIZE=30

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Bull Queue
BULL_PREFIX=parkfan

# Origin rate limiting (circuit breaker; keyed on CF-Connecting-IP).
# Generous by default so carrier-NAT'd mobile users aren't punished.
# Set THROTTLE_LIMIT=0 to disable.
# THROTTLE_TTL=60
# THROTTLE_LIMIT=300
# Frontend bypass: requests sending THROTTLE_BYPASS_HEADER with one of the
# comma-separated keys skip the limiter. Set a long random secret here and
# in the frontend. Shared secret, not auth — rotate via env, never commit.
# THROTTLE_BYPASS_HEADER=x-auth-key
# THROTTLE_BYPASS_KEYS=CHANGE_ME_LONG_RANDOM_SECRET

# External APIs
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE
# Weather uses Open-Meteo (no API key required)

# ML Service Configuration
ML_SERVICE_URL=http://ml-service:8000
MODEL_DIR=/app/models

# Frontend on-demand revalidation webhook (best-days snapshot refresh).
# After the daily forecast batch refreshes the precomputed best-days snapshots,
# the backend POSTs {tags:[...]} to REVALIDATE_URL so the frontend drops its
# stale best-days cache immediately. Disabled unless REVALIDATE_SECRET is set.
# The secret is sent as the `x-revalidate-secret` header (must match frontend).
REVALIDATE_URL=https://park.fan/api/revalidate
REVALIDATE_SECRET=CHANGE_ME_SHARED_WITH_FRONTEND
